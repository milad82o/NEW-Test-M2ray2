{
  "name": "g2ray",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "postAttachCommand": "gh codespace ports visibility 443:public -c $CODESPACE_NAME && bash /usr/local/bin/startup.sh",
  "portsAttributes": {
    "443": {
      "label": "g2ray",
      "protocol": "http",
      "onAutoForward": "silent"
    },
    "3000": {
      "label": "webui",
      "protocol": "http",
      "onAutoForward": "notify"
    }
  },
  "forwardPorts": [443, 3000],
  "hostRequirements": {
    "cpus": 2
  }
}
